<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/view_home_tab"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/transparent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <!-- Auto Clean Area with Circular Progress -->
            <FrameLayout
                android:id="@+id/layout_clean_container"
                android:layout_width="@dimen/_170sdp"
                android:layout_height="@dimen/_170sdp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Circular Progress Indicator -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    app:indicatorSize="@dimen/_150sdp"
                    app:trackThickness="@dimen/_8sdp"
                    app:trackColor="#1F293D"
                    app:indicatorColor="@color/primary"
                    android:progress="0"
                    android:max="100" />

                <!-- Auto Clean Broom Circle -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/btn_main_auto_clean"
                    android:layout_width="@dimen/_120sdp"
                    android:layout_height="@dimen/_120sdp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_cleaner"
                    android:background="@drawable/blue_circle_bg"
                    android:padding="@dimen/_26sdp"
                    android:scaleType="fitCenter"
                    android:elevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/white"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Circle" />

            </FrameLayout>

            <!-- Status details block -->
            <LinearLayout
                android:id="@+id/layout_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/layout_clean_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_current_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to clean"
                    android:textSize="18sp"
                    android:fontFamily="@font/sora_bold"
                    android:textColor="@color/black" />

                <TextView
                    android:id="@+id/tv_time_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thời gian còn lại: 0s"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary_light"
                    android:layout_marginTop="6dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_live_frequency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Hz"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_stop_cleaning"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dừng lại"
                    android:textColor="@color/error"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Tap to remove water banner label -->
            <TextView
                android:id="@+id/tv_tap_banner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to remove water"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="@font/sora_regular"
                android:letterSpacing="0.08"
                android:textColor="@color/primary_blue_selected"
                android:layout_marginTop="5dp"
                app:layout_constraintTop_toBottomOf="@id/layout_status"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Action Lists -->
            <LinearLayout
                android:id="@+id/layout_action_cards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_tap_banner"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Card 1: Làm sạch thủ công -->
                <FrameLayout
                    android:id="@+id/card_manual_clean"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_home_action_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_brush"
                            app:tint="#D946EF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Làm sạch thủ công"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/sora_bold"
                            android:layout_marginStart="16dp"
                            android:textColor="#1A202C" />

                    </LinearLayout>
                </FrameLayout>

                <!-- Card 2: Làm sạch bằng rung -->
                <FrameLayout
                    android:id="@+id/card_vibration_clean"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_home_action_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_vibration"
                            app:tint="#10B981" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Làm sạch bằng rung"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/sora_bold"
                            android:layout_marginStart="16dp"
                            android:textColor="#1A202C" />

                    </LinearLayout>
                </FrameLayout>

                <!-- Card 3: Thổi khí -->
                <FrameLayout
                    android:id="@+id/card_air_blow"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:background="@drawable/bg_home_action_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_fan"
                            app:tint="#F43F5E" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thổi khí"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/sora_bold"
                            android:layout_marginStart="16dp"
                            android:textColor="#1A202C" />

                    </LinearLayout>
                </FrameLayout>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</layout>
