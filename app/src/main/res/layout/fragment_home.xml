<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/view_home_tab"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/transparent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingBottom="20dp">

            <!-- Active status details above circle -->
            <LinearLayout
                android:id="@+id/layout_active_status_top"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:visibility="invisible"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_time_remaining"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time Remaining: 0s"
                    android:textSize="14sp"
                    android:textColor="#94A3B8"
                    android:fontFamily="@font/sora_regular" />

                <TextView
                    android:id="@+id/tv_live_frequency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Hz"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_blue_selected"
                    android:fontFamily="@font/sora_bold"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Auto Clean Area with Circular Progress -->
            <FrameLayout
                android:id="@+id/layout_clean_container"
                android:layout_width="@dimen/_170sdp"
                android:layout_height="@dimen/_170sdp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/layout_active_status_top"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Circular Progress Indicator -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    app:indicatorSize="@dimen/_150sdp"
                    app:trackThickness="@dimen/_10sdp"
                    app:trackColor="#E5EFFF"
                    app:indicatorColor="@color/primary_blue_selected"
                    android:progress="0"
                    android:max="100" />

                <!-- Auto Clean Broom Circle -->
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/btn_main_auto_clean"
                    android:layout_width="@dimen/_130sdp"
                    android:layout_height="@dimen/_130sdp"
                    android:layout_gravity="center"
                    app:lottie_rawRes="@raw/anim_cleaner"
                    app:lottie_autoPlay="false"
                    app:lottie_loop="true"
                    android:scaleType="fitCenter"
                    android:clickable="true"
                    android:focusable="true" />

            </FrameLayout>

            <!-- Status details block below circle -->
            <LinearLayout
                android:id="@+id/layout_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/layout_clean_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_current_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to clean"
                    android:textSize="20sp"
                    android:fontFamily="@font/sora_bold"
                    android:textColor="#1A202C"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_stop_cleaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to stop"
                    android:textColor="#FF3B30"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/sora_bold"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Tap to remove water banner label -->
            <TextView
                android:id="@+id/tv_tap_banner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap to remove water"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="@font/sora_regular"
                android:letterSpacing="0.08"
                android:textColor="@color/primary_blue_selected"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/layout_status"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Action Lists -->
            <LinearLayout
                android:id="@+id/layout_action_cards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tv_tap_banner"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Card 1: Làm sạch thủ công -->
                <FrameLayout
                    android:id="@+id/card_manual_clean"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_home_action_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_brush"
                            app:tint="#D946EF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manual Cleaning"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/sora_bold"
                            android:layout_marginStart="16dp"
                            android:textColor="#1A202C" />

                    </LinearLayout>
                </FrameLayout>

                <!-- Card 2: Làm sạch bằng rung -->
                <FrameLayout
                    android:id="@+id/card_vibration_clean"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_home_action_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_vibration"
                            app:tint="#10B981" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vibration Cleaning"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/sora_bold"
                            android:layout_marginStart="16dp"
                            android:textColor="#1A202C" />

                    </LinearLayout>
                </FrameLayout>

                <!-- Card 3: Thổi khí -->
                <FrameLayout
                    android:id="@+id/card_air_blow"
                    android:layout_width="match_parent"
                    android:layout_height="76dp"
                    android:background="@drawable/bg_home_action_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="24dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_fan"
                            app:tint="#F43F5E" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Air Blow"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/sora_bold"
                            android:layout_marginStart="16dp"
                            android:textColor="#1A202C" />

                    </LinearLayout>
                </FrameLayout>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</layout>
