<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.LinearLayout"
    tools:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/label_custom_frequency"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A202C" />

        <TextView
            android:id="@+id/tv_slider_frequency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1000 Hz"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue_selected" />
    </LinearLayout>

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_frequency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:labelBehavior="gone"
        app:thumbColor="@color/primary_blue_selected"
        app:trackColorActive="@color/primary_blue_selected"
        app:trackColorInactive="#E5EFFF"
        app:thumbHeight="20dp"
        app:thumbWidth="20dp"
        app:trackHeight="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="50 Hz"
            android:textSize="12sp"
            android:textColor="#94A3B8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10,000 Hz"
            android:textSize="12sp"
            android:textColor="#94A3B8" />
    </LinearLayout>
</merge>
