<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.LinearLayout"
    tools:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tần số thủ công"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tv_slider_frequency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1000 Hz"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary" />
    </LinearLayout>

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_frequency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:labelBehavior="gone"
        app:thumbColor="@color/primary"
        app:trackColorActive="@color/primary"
        app:trackColorInactive="@color/gray_light" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="50 Hz"
            android:textSize="12sp"
            android:textColor="@color/text_secondary_light" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10,000 Hz"
            android:textSize="12sp"
            android:textColor="@color/text_secondary_light" />
    </LinearLayout>
</merge>
