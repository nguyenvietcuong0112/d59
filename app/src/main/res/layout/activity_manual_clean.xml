<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_app_gradient"
        android:padding="20dp"
        tools:context=".presentation.ui.ManualCleanActivity">

        <!-- Top Navigation Bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:background="@drawable/circle_glass_bg"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LÃ m sáº¡ch thá»§ cÃ´ng"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Visual frequency circle indicator -->
        <FrameLayout
            android:id="@+id/layout_circle_wrapper"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/layout_toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Background circle -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_glass_bg" />

            <!-- Blue ring indicating active state -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/manual_progress_indicator"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                app:indicatorSize="190dp"
                app:trackThickness="10dp"
                app:indicatorColor="@color/primary"
                app:trackColor="#1F293D"
                android:progress="0"
                android:max="100" />

            <!-- Inside text showing frequency -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_manual_state"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sáºµn sÃ ng"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary_light"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_manual_frequency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1000 Hz"
                    android:textSize="26sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </FrameLayout>

        <!-- Control Slider -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/gray_light"
            app:cardBackgroundColor="@color/surface_light"
            app:layout_constraintTop_toBottomOf="@id/layout_circle_wrapper">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.removedust.speaker.cleaner.presentation.component.FrequencySlider
                    android:id="@+id/frequency_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Play/Stop control button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_manual_start_stop"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Báº¯t Ä‘áº§u"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            app:icon="@android:drawable/ic_media_play"
            app:backgroundTint="@color/primary"
            app:cornerRadius="18dp"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
