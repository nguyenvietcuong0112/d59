<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_app_gradient"
        android:padding="20dp"
        tools:context=".presentation.ui.VibrationCleanActivity">

        <!-- Top Navigation Bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:background="@drawable/circle_glass_bg"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Làm sạch bằng rung"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Wave Graphic and Circular display container -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_wave_container"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/layout_toolbar">

            <!-- Background Waves -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_wave_bg"
                android:scaleType="fitCenter"
                android:alpha="0.4"
                app:tint="@color/primary" />

            <!-- Large Blue Circle -->
            <FrameLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/blue_circle_bg"
                android:elevation="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tv_device_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loa"
                        android:textSize="18sp"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_vibration_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 %"
                        android:textSize="32sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Mode selector: Chọn loại -->
        <TextView
            android:id="@+id/tv_mode_heading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn loại"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/layout_wave_container"
            app:layout_constraintStart_toStartOf="parent" />

        <LinearLayout
            android:id="@+id/layout_selector_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_mode_heading">

            <!-- Normal Mode Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_mode_normal"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="60dp"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="@color/gray_light"
                app:cardBackgroundColor="@color/surface_light"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:id="@+id/iv_mode_normal"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_vibration"
                        app:tint="@color/text_secondary_light" />

                    <TextView
                        android:id="@+id/tv_mode_normal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bình thường"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary_light"
                        android:layout_marginStart="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Strong Mode Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_mode_strong"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="60dp"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="@color/gray_light"
                app:cardBackgroundColor="@color/surface_light"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:id="@+id/iv_mode_strong"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_vibration"
                        app:tint="@color/text_secondary_light" />

                    <TextView
                        android:id="@+id/tv_mode_strong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mạnh"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary_light"
                        android:layout_marginStart="8dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Start / Stop Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_vibration_start_stop"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Bắt đầu"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="18dp"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
