<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_app_gradient"
        tools:context=".presentation.ui.vibration.VibrationCleanActivity">

        <!-- Top Navigation Bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:paddingHorizontal="@dimen/_10sdp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back_arrow"
                android:background="@drawable/bg_settings_circle_button"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                app:tint="#1A202C"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_vibration_cleaning"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/sora_bold"
                android:textColor="#1A202C"
                android:layout_marginStart="16dp"
                app:layout_constraintStart_toEndOf="@id/btn_back"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <FrameLayout
            android:id="@+id/fr_ads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent">

            <include layout="@layout/ads_shimmer_native_full" />
        </FrameLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:paddingHorizontal="@dimen/_10sdp"
            app:layout_constraintTop_toBottomOf="@id/layout_toolbar"
            app:layout_constraintBottom_toTopOf="@id/fr_ads">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingBottom="16dp">

                <!-- Center Circle Card with Lottie Glow wrapper -->
                <FrameLayout
                    android:id="@+id/layout_circle_wrapper_parent"
                    android:layout_width="@dimen/_210sdp"
                    android:layout_height="@dimen/_210sdp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:layout_marginTop="8dp">

                    <!-- 1. Lottie Animation for Glow (bottom layer) -->
                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottie_glow"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:lottie_rawRes="@raw/glowing"
                        app:lottie_autoPlay="false"
                        app:lottie_speed="1.2"
                        app:lottie_loop="true"
                        android:visibility="invisible" />

                    <!-- 2. Outer Circle Card (middle layer, on top of Lottie) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/layout_circle_wrapper_outer"
                        android:layout_width="@dimen/_150sdp"
                        android:layout_height="@dimen/_150sdp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="@dimen/_95sdp"
                        app:cardElevation="6dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="@color/white">

                        <View
                            android:id="@+id/view_idle_gradient"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_manual_circle_gradient" />

                        <!-- Active state blue ring -->
                        <View
                            android:id="@+id/view_active_blue_ring"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@color/primary_blue_selected"
                            android:visibility="invisible" />

                        <!-- 3. Inner Circle Card (nested inside Outer Circle Card) -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/layout_circle_wrapper"
                            android:layout_width="@dimen/_130sdp"
                            android:layout_height="@dimen/_130sdp"
                            android:layout_gravity="center"
                            app:cardCornerRadius="@dimen/_85sdp"
                            app:cardElevation="6dp"
                            app:strokeWidth="0dp"
                            app:cardBackgroundColor="@color/white">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_manual_circle_gradient" />

                            <!-- Inside Text showing progress -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:id="@+id/tv_device_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/label_speaker"
                                    android:textSize="14sp"
                                    android:textColor="#94A3B8"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_vibration_percent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="32sp"
                                    android:textColor="@color/primary_blue_selected"
                                    android:textStyle="bold"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </com.google.android.material.card.MaterialCardView>

                </FrameLayout>

                <!-- Mode selector: Select type -->
                <TextView
                    android:id="@+id/tv_mode_heading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_type"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A202C"
                    android:layout_gravity="start"
                    android:layout_marginTop="16dp" />

                <LinearLayout
                    android:id="@+id/layout_selector_row"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <!-- Normal Mode Button -->
                    <LinearLayout
                        android:id="@+id/card_mode_normal"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_vibration_card_selector"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp">

                        <ImageView
                            android:id="@+id/iv_mode_normal"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_phone_mode"
                            android:duplicateParentState="true"
                            app:tint="@color/color_vibration_text_selector" />

                        <TextView
                            android:id="@+id/tv_mode_normal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/type_normal"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:duplicateParentState="true"
                            android:textColor="@color/color_vibration_text_selector"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <!-- Strong Mode Button -->
                    <LinearLayout
                        android:id="@+id/card_mode_strong"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_vibration_card_selector"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp">

                        <ImageView
                            android:id="@+id/iv_mode_strong"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_phone_mode"
                            android:duplicateParentState="true"
                            app:tint="@color/color_vibration_text_selector" />

                        <TextView
                            android:id="@+id/tv_mode_strong"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/type_strong"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:duplicateParentState="true"
                            android:textColor="@color/color_vibration_text_selector"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_vibration_start_stop"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="20dp"
                    android:text="@string/btn_start"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/primary_blue_selected"
                    app:cornerRadius="16dp"
                    app:elevation="4dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
