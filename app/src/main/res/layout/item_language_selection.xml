<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSelection"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_language_item_unselected"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="@dimen/_12sdp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <!-- Rounded Flag Icon -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivFlag"
            android:layout_width="38dp"
            android:layout_height="26dp"
            android:scaleType="centerCrop"
            android:layout_marginEnd="16dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.RoundedFlag"
            android:src="@drawable/flag_us" />

        <!-- Language Name Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#1A202C"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="English" />

        <!-- Custom Radio Button Indicator -->
        <ImageView
            android:id="@+id/ivCheckIndicator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Selection Indicator"
            android:src="@drawable/ic_radio_unchecked" />

    </LinearLayout>

</FrameLayout>
