<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- Title -->
        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Volume Warning"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A202C"
            android:fontFamily="@font/sora_bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Message -->
        <TextView
            android:id="@+id/tv_dialog_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Please turn your volume to MAXIMUM and place your phone screen down for the best results."
            android:textSize="14sp"
            android:textColor="#4A5568"
            android:fontFamily="@font/sora_regular"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="24dp" />

        <!-- Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal">

            <!-- Cancel Button -->
            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_vibration_card_unselected"
                android:gravity="center"
                android:text="Cancel"
                android:textColor="@color/primary_blue_selected"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/sora_bold"
                android:clickable="true"
                android:focusable="true" />

            <!-- Got it Button -->
            <TextView
                android:id="@+id/btn_confirm"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_dialog_btn_confirm"
                android:gravity="center"
                android:text="Got it"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/sora_bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
