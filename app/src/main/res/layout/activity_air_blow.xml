<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_app_gradient"
        android:padding="20dp"
        tools:context=".presentation.ui.AirBlowActivity">

        <!-- Top Navigation Bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:background="@drawable/circle_glass_bg"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thổi khí"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Center Fan Casing and Propeller -->
        <FrameLayout
            android:id="@+id/layout_fan_casing"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/ic_fan_box_bg"
            android:padding="24dp"
            app:layout_constraintTop_toBottomOf="@id/layout_toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iv_propeller"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_fan"
                android:scaleType="fitCenter"
                app:tint="@color/white" />
        </FrameLayout>

        <!-- Speed scale visual box -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layout_scale_box"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/gray_light"
            app:cardBackgroundColor="@color/surface_light"
            app:layout_constraintTop_toBottomOf="@id/layout_fan_casing">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Ruler Scale -->
                <ImageView
                    android:id="@+id/iv_ruler_scale"
                    android:layout_width="280dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_ruler_scale"
                    app:tint="@color/white"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Scale range labels -->
                <TextView
                    android:id="@+id/tv_low_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Low"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary_light"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/iv_ruler_scale"
                    app:layout_constraintStart_toStartOf="@id/iv_ruler_scale" />

                <TextView
                    android:id="@+id/tv_medium_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medium"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary_light"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/iv_ruler_scale"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <TextView
                    android:id="@+id/tv_high_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="High"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary_light"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@id/iv_ruler_scale"
                    app:layout_constraintEnd_toEndOf="@id/iv_ruler_scale" />

                <!-- Arrow indicator -->
                <ImageView
                    android:id="@+id/iv_scale_arrow"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_green_arrow"
                    android:layout_marginTop="20dp"
                    app:tint="@color/primary"
                    app:layout_constraintTop_toBottomOf="@id/tv_medium_label"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Speed selectors buttons -->
        <LinearLayout
            android:id="@+id/layout_speed_selectors"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toBottomOf="@id/layout_scale_box">

            <!-- Thấp button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_speed_low"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:text="Thấp"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/neon_yellow"
                app:cornerRadius="14dp" />

            <!-- Trung bình button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_speed_medium"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:text="Trung bình"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/primary"
                app:cornerRadius="14dp" />

            <!-- Tăng cường button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_speed_boost"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:text="Tăng cường"
                android:textColor="@color/white"
                android:textStyle="bold"
                app:backgroundTint="@color/success"
                app:cornerRadius="14dp" />
        </LinearLayout>

        <!-- Circular Red Power button at the bottom -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/btn_power_start_stop"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:src="@drawable/ic_power"
            android:background="@drawable/circle_red_bg"
            android:elevation="6dp"
            android:padding="20dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="32dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Circle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
