<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:clickable="true"
    android:focusable="true">

    <!-- FrameLayout to display the actual Native Full ad -->
    <FrameLayout
        android:id="@+id/layoutAds"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <include layout="@layout/admob_layout_native_full_inter" />
    </FrameLayout>

    <!-- Top control area (Countdown / Close button) -->
    <FrameLayout
        android:id="@+id/closeContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp">

<!--        &lt;!&ndash; Countdown TextView (shown during countdown) &ndash;&gt;-->
        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="3"
            android:textColor="@android:color/transparent"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone"/>

        <!-- Next / Close Button (hidden during countdown, shown after) -->
        <TextView
            android:id="@+id/btnNext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:background="@drawable/close_ful_ads"
            android:visibility="gone"
            />
    </FrameLayout>
</FrameLayout>
