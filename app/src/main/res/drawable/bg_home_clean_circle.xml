<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- 1. Shadow Layer (shifted down: Y = 6dp) -->
    <item
        android:left="0dp"
        android:top="6dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="#1A000000" />
        </shape>
    </item>

    <!-- 2. Content Layer (White Circle) -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="6dp">
        <shape android:shape="oval">
            <solid android:color="@color/white" />
        </shape>
    </item>
    
</layer-list>
